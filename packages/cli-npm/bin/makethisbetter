#!/usr/bin/env node
const { execFileSync } = require("child_process");
const path = require("path");
const fs = require("fs");

const PLATFORM_MAP = {
  darwin: {
    arm64: "@makethisbetter/cli-darwin-arm64",
    x64: "@makethisbetter/cli-darwin-x64",
  },
  linux: {
    arm64: "@makethisbetter/cli-linux-arm64",
    x64: "@makethisbetter/cli-linux-x64",
  },
  win32: {
    x64: "@makethisbetter/cli-win32-x64",
  },
};

function getBinaryPath() {
  const platformPkgs = PLATFORM_MAP[process.platform];
  if (!platformPkgs) {
    throw new Error("Unsupported platform: " + process.platform);
  }

  const pkg = platformPkgs[process.arch];
  if (!pkg) {
    throw new Error(
      "Unsupported architecture: " +
        process.arch +
        " on " +
        process.platform
    );
  }

  // Try optionalDependency first
  try {
    return require.resolve(pkg + "/bin/makethisbetter");
  } catch {}

  // Fallback to postinstall download location
  const ext = process.platform === "win32" ? ".exe" : "";
  const fallback = path.join(__dirname, "..", "downloaded", "makethisbetter" + ext);
  if (fs.existsSync(fallback)) {
    return fallback;
  }

  throw new Error(
    "Could not find the makethisbetter binary. " +
      "Try reinstalling: npm install -g @makethisbetter/cli\n" +
      "Or install from source: go install github.com/makethisbetter/cli@latest"
  );
}

try {
  execFileSync(getBinaryPath(), process.argv.slice(2), { stdio: "inherit" });
} catch (e) {
  if (e.status !== undefined) {
    process.exit(e.status);
  }
  console.error(e.message);
  process.exit(1);
}
